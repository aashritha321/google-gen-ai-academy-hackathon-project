# NyayaMitra AI - Configuration Variables

# --- GOOGLE AI STUDIO (Gemini API Key) CONFIGURATION ---
# Set this variable to use Gemini Developer API / Google AI Studio.
GEMINI_API_KEY=your_gemini_api_key_here

# --- GOOGLE VERTEX AI (GCP) CONFIGURATION ---
# Set these variables to use Gemini on Google Cloud Platform Vertex AI.
# If GOOGLE_GENAI_USE_VERTEXAI is true, the SDK will run in Vertex AI mode.
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=your_gcp_project_id_here
GOOGLE_CLOUD_LOCATION=us-central1

# Optional: Path to GCP Service Account Credentials JSON file (for local Vertex AI testing)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
